# Database configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=retail_intelligence
DATABASE_USER=retail_user
DATABASE_PASSWORD=change_me

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=retail_intelligence.log

# Project directories
DATA_DIR=data
SOURCE_DATA_DIR=data/source
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
EXPORT_DATA_DIR=data/exports

# API configuration
RETAIL_API_KEY=

# AI configuration
GROQ_API_KEY=
OPENAI_API_KEY=
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Airflow configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW_DAG_DIR=/opt/airflow/dags

# Spark configuration
SPARK_MASTER_URL=local[*]
SPARK_APP_NAME=RetailIntelligencePlatform
